# deploy 스크립트 공통 설정. 이 파일을 config.sh 로 복사한 뒤 값을 채우세요.
#   cp deploy/config.sh.example deploy/config.sh
# config.sh 는 비밀정보(인스턴스 ID 등)를 담으므로 git에 올리지 마세요(.gitignore 등록).

# GPU 워커로 쓸 EC2 인스턴스 ID
export GPU_INSTANCE_ID="i-0123456789abcdef0"

# 인스턴스가 있는 리전 (서울)
export AWS_REGION="ap-northeast-2"

# 로컬(노트북)에서 인스턴스에 SSH 접속할 정보 — submit_job.sh 에서 사용
export SSH_HOST="ubuntu@your-elastic-ip-or-dns"
export SSH_KEY="$HOME/.ssh/billiard.pem"

# 인스턴스 안에서의 레포 경로
export REPO_DIR="/home/ubuntu/26s-w3-c3-01"

# 유휴 상태가 이 횟수만큼 연속되면 인스턴스를 정지 (cron 주기 × 이 값 = 실제 대기시간)
export IDLE_CYCLES_BEFORE_STOP="2"

# --- 결과 저장(S3) / 원본 영상 정리 ---
# 결과(turns.jsonl/csv, traj.json, qa/)를 업로드할 S3 버킷. 비우면 S3 업로드를 건너뛰고
# 로컬 EBS 에만 저장한다. 임시 인스턴스는 정지·종료될 수 있으니 실서비스에선 반드시 설정 권장.
export S3_BUCKET="s3://your-billiard-results-bucket"
export S3_PREFIX="results"

# 추출 성공 후 원본 영상(수 GB)을 지울지. "1"이면 보존, 비우면 삭제(기본, 디스크 절약).
export KEEP_VIDEOS=""
